APP_NAME=ControlBox
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=change-me-to-a-64-char-random-string-in-production-abc123xyz
APP_API_PREFIX=/api/v1

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=controlbox
POSTGRES_USER=controlbox
POSTGRES_PASSWORD=change-me-strong-password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_DB=0

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

SITES_BASE_PATH=/var/lib/controlbox/sites
DATABASE_BACKUPS_PATH=/var/lib/controlbox/backups/databases

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ADMIN_USER=root
MYSQL_ADMIN_PASSWORD=change-me-mysql-root

MARIADB_HOST=mariadb
MARIADB_PORT=3306
MARIADB_ADMIN_USER=root
MARIADB_ADMIN_PASSWORD=change-me-mariadb-root

MANAGED_POSTGRES_HOST=managed-postgres
MANAGED_POSTGRES_PORT=5432
MANAGED_POSTGRES_ADMIN_USER=postgres
MANAGED_POSTGRES_ADMIN_PASSWORD=change-me-managed-postgres

MSSQL_HOST=mssql
MSSQL_PORT=1433
MSSQL_ADMIN_USER=sa
MSSQL_ADMIN_PASSWORD=YourStrong!Passw0rd

SUPABASE_DB_HOST=supabase-db
SUPABASE_DB_PORT=5432
SUPABASE_DB_ADMIN_USER=postgres
SUPABASE_DB_ADMIN_PASSWORD=change-me-supabase-db
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters
SUPABASE_URL=http://supabase-kong:8000
SUPABASE_STORAGE_URL=http://supabase-storage:5000
SUPABASE_STUDIO_URL=http://supabase-studio:3000
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

POWERDNS_API_URL=http://powerdns:8081
POWERDNS_API_KEY=changeme
POWERDNS_SERVER_ID=localhost
POWERDNS_DEFAULT_TTL=3600
POWERDNS_NAMESERVERS=ns1.controlbox.io,ns2.controlbox.io

PUREFTPD_ENABLED=true
PUREFTPD_HOST=localhost
PUREFTPD_PORT=21
PUREFTPD_PUBLIC_HOST=localhost
PUREFTPD_CONTAINER=controlbox-pureftpd
PUREFTPD_USE_DOCKER=true
PUREFTPD_PASSWD_FILE=/etc/pure-ftpd/pureftpd.passwd
PUREFTPD_LOG_PATH=/var/log/pure-ftpd/transfer.log
PUREFTPD_VIRTUAL_UID=1000
PUREFTPD_VIRTUAL_GID=1000

BACKUPS_BASE_PATH=/var/lib/controlbox/backups
MINIO_ROOT_USER=minioadmin
MONITORING_INTERVAL_SECONDS=5
MONITORING_USE_DOCKER=true

SECURITY_ENABLED=true
SECURITY_WAF_ENABLED=true
SECURITY_BRUTE_FORCE_ENABLED=true
SECURITY_BRUTE_FORCE_MAX_ATTEMPTS=5
SECURITY_BRUTE_FORCE_BLOCK_SECONDS=3600
SECURITY_RATE_LIMIT_LOGIN=10
SECURITY_RATE_LIMIT_API=300
SECURITY_TRUST_PROXY=true
SECURITY_CSP=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ws: wss:; frame-ancestors 'none'

WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=ControlBox
WEBAUTHN_ORIGIN=http://localhost:3000

CROWDSEC_ENABLED=false
CROWDSEC_LAPI_URL=http://crowdsec:8080

REGISTRATION_ENABLED=false
REGISTRATION_INVITE_TOKEN=change-me-invite-token
SECURITY_CSRF_ENABLED=true
UVICORN_WORKERS=1
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
BACKGROUND_TASKS_ENABLED=true
SECURITY_RATE_LIMIT_GLOBAL=600

# Docker API via socket proxy (set in compose for api service; do not mount docker.sock into api)
DOCKER_HOST=tcp://docker-socket-proxy:2375

CELERY_BROKER_URL=redis://:change-me-redis@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:change-me-redis@localhost:6379/2
